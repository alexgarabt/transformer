{
    "model": {
        "d_model": 768,
        "n_heads": 12,
        "n_layers": 12,
        "d_ff": 2560,
        "max_seq_len": 1024,
        "dropout": 0.0,
        "activation": "swiglu",
        "norm": "rmsnorm",
        "norm_first": true,
        "bias": false,
        "pos_encoding": "learned",
        "weight_tying": true
    },
    "training": {
        "batch_size": 128,
        "learning_rate": 6e-4,
        "max_epochs": 1,
        "grad_clip": 1.0,
        "log_every": 100,
        "device": "cuda",
        "checkpoint_dir": "checkpoints/llama_124m",
        "tensorboard_dir": "runs/llama_124m",
        "precision": "bfloat16",
        "gradient_accumulation_steps": 4
    },
    "tokenizer_path": "data/tok_32k.model",
    "train_data": "data/train_10bt.npy",
    "val_data": "data/val_10bt.npy",
    "warmup_steps": 750,
    "seed": 42
}
