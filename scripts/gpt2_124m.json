{
    "model": {
        "vocab_size": 50257,
        "d_model": 768,
        "n_heads": 12,
        "n_layers": 12,
        "d_ff": 3072,
        "max_seq_len": 1024,
        "dropout": 0.0,
        "activation": "gelu",
        "norm": "layernorm",
        "norm_first": true,
        "bias": true,
        "pos_encoding": "learned",
        "weight_tying": true
    },
    "training": {
        "batch_size": 64,
        "learning_rate": 6e-4,
        "max_epochs": 1,
        "grad_clip": 1.0,
        "pad_id": 0,
        "log_every": 50,
        "device": "cuda",
        "checkpoint_dir": "checkpoints/gpt2_124m",
        "tensorboard_dir": "runs/gpt2_124m"
    },
    "tokenizer_path": "data/tok_gpt2.model",
    "warmup_steps": 700,
    "seed": 42
}
